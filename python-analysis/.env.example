# Copy this file to .env and fill in your values

# Option A: load data from the AktieKoll REST API
API_BASE_URL=https://your-aktiekoll-api.azurewebsites.net

# Option B: path to a local FI CSV export (UTF-16, semicolon-delimited)
# Leave blank to use the API instead
CSV_PATH=

# Output directory for plots
OUTPUT_DIR=output
